# Windows-specific configuration with architecture support
export KVXOPT_BLAS_LIB=openblas
export KVXOPT_LAPACK_LIB=openblas
export CMAKE_GENERATOR="Visual Studio 17 2022"

# Architecture-specific paths (will be set by build script)
# KVXOPT_BLAS_LIB_DIR, KVXOPT_BLAS_INC_DIR, PATH will be set based on ARCH
